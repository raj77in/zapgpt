FROM python:3.12-slim

ENV PYTHONDONTWRITEBYTECODE=1 \
    PYTHONUNBUFFERED=1 \
    PYTHONPATH=/app \
    OPENAI_API_KEY=dummy_key_for_testing \
    OPENROUTER_KEY=dummy_key_for_testing \
    TOGETHER_API_KEY=dummy_key_for_testing \
    REPLICATE_API_TOKEN=dummy_key_for_testing \
    DEEPINFRA_API_TOKEN=dummy_key_for_testing \
    GITHUB_KEY=dummy_key_for_testing

WORKDIR /app

COPY pyproject.toml README.md LICENSE ./
COPY zapgpt ./zapgpt
COPY tests ./tests

RUN python -m pip install --no-cache-dir ".[test]"

CMD ["python", "-m", "pytest", "tests", "-q"]
